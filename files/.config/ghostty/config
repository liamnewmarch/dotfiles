theme = llama

font-family = Fira Code
font-family = Fira Code Retina
font-size = 13

# tmux prefix (deprecated)
# keybind = super+a=text:\x01

# tmux compat
keybind = super+a>backslash=new_split:right
keybind = super+a>down=goto_split:left
keybind = super+a>left=goto_split:left
keybind = super+a>minus=new_split:down
keybind = super+a>n=new_tab
keybind = super+a>right=goto_split:right
keybind = super+a>s=ignore
keybind = super+a>t=new_tab
keybind = super+a>up=goto_split:up
keybind = super+a>z=toggle_split_zoom

# clear screen
keybind = ctrl+k=text:\x0c
keybind = super+k=text:\x0c
keybind = super+l=text:\x0c

macos-option-as-alt = right

quit-after-last-window-closed = true

shell-integration = none
shell-integration-features = false

term = xterm-256color

title = " "

window-padding-balance = true
window-padding-x = 13
window-padding-y = 13

window-width = 120
window-height = 42
