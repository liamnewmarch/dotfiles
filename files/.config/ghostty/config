theme = llama

font-family = Fira Code
font-family = Fira Code Retina
font-size = 13

macos-option-as-alt = right

quit-after-last-window-closed = true

shell-integration = none
shell-integration-features = false

term = xterm-256color

window-padding-balance = true
window-padding-x = 13
window-padding-y = 13

window-width = 120
window-height = 42

# tmux compat
keybind = super+a>backslash=new_split:right
keybind = super+a>minus=new_split:down
keybind = super+a>n=new_window
keybind = super+a>r=prompt_surface_title
keybind = super+a>t=new_tab
keybind = super+a>z=toggle_split_zoom

# Create splits
keybind = super+a>s>down=new_split:down
keybind = super+a>s>left=new_split:left
keybind = super+a>s>right=new_split:right
keybind = super+a>s>up=new_split:up

# Go to splits
keybind = super+a>down=goto_split:down
keybind = super+a>left=goto_split:left
keybind = super+a>right=goto_split:right
keybind = super+a>up=goto_split:up

# Go to tab
keybind = super+left=previous_tab
keybind = super+right=next_tab

# Clear screen
keybind = ctrl+k=text:\x0c
keybind = ctrl+l=text:\x0c
keybind = super+k=text:\x0c
keybind = super+l=text:\x0c
